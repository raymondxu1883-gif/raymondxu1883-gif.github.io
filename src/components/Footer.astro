---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { href: './services.html#signage', label: 'Signage Design' },
    { href: './services.html#banners', label: 'Banners' },
    { href: './services.html#stickers', label: 'Custom Stickers' },
    { href: './services.html#events', label: 'Event Signage' },
    { href: './services.html#print', label: 'Print Design' },
  ],
  company: [
    { href: './about.html', label: 'About Us' },
    { href: './portfolio.html', label: 'Portfolio' },
    { href: './blog.html', label: 'Blog' },
    { href: './contact.html', label: 'Contact' },
  ],
  legal: [
    { href: './privacy.html', label: 'Privacy Policy' },
    { href: './terms.html', label: 'Terms of Service' },
  ],
};

const socialLinks = [
  { href: '#', label: 'Instagram', icon: 'instagram' },
  { href: '#', label: 'LinkedIn', icon: 'linkedin' },
  { href: '#', label: 'Behance', icon: 'behance' },
  { href: '#', label: 'Pinterest', icon: 'pinterest' },
];
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="./" class="flex items-center gap-2 text-xl font-bold mb-4">
          <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="8" fill="white"/>
            <path d="M10 20L16 14L22 20L30 12V28H10V20Z" fill="#ff6b35"/>
            <circle cx="16" cy="20" r="2" fill="#1a1a1a"/>
          </svg>
          <span>SignSmith Studio</span>
        </a>
        <p class="text-gray-400 mb-6 max-w-sm">
          We help small shops, local businesses, and individuals get professional signs — easily, affordably, and with a personal touch.
        </p>
        <div class="flex gap-4">
          {socialLinks.map(social => (
            <a 
              href={social.href}
              class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-orange-500 transition-colors"
              aria-label={social.label}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                {social.icon === 'instagram' && (
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                )}
                {social.icon === 'linkedin' && (
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                )}
                {social.icon === 'behance' && (
                  <path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H0V5.021h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zM3 11h3.584c2.508 0 2.906-3-.312-3H3v3zm3.391 3H3v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/>
                )}
                {social.icon === 'pinterest' && (
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
                )}
              </svg>
            </a>
          ))}
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h3 class="font-semibold mb-4">Services</h3>
        <ul class="space-y-3">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Company -->
      <div>
        <h3 class="font-semibold mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Newsletter -->
      <div>
        <h3 class="font-semibold mb-4">Stay Updated</h3>
        <p class="text-gray-400 text-sm mb-4">Get design tips and exclusive offers.</p>
        <form class="flex gap-2" onsubmit="event.preventDefault(); alert('Thanks for subscribing!');">
          <input 
            type="email" 
            placeholder="Your email" 
            class="flex-1 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-500 focus:outline-none focus:border-orange-500"
            required
          />
          <button type="submit" class="px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition-colors text-sm font-medium">
            Join
          </button>
        </form>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">
        © {currentYear} SignSmith Studio. All rights reserved.
      </p>
      <div class="flex gap-6">
        {footerLinks.legal.map(link => (
          <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
