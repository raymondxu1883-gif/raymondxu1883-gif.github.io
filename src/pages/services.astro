---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'signage',
    icon: 'signage',
    title: 'Custom Signage',
    shortDesc: 'Professional signs for every need',
    fullDesc: 'From storefront signs to office directories, we design AND manufacture signage that captures attention. With direct factory partnerships, we deliver quality signs at competitive prices. Available in acrylic, PVC, metal, wood, and more.',
    image: '/images/work-signage.jpg',
    features: [
      'Indoor & outdoor signage',
      'Acrylic & PVC signs',
      'Dimensional lettering',
      'Backlit & illuminated signs',
      'ADA compliant signage',
      'Wayfinding systems'
    ],
    priceRange: 'From $150',
    turnaround: '5-7 days'
  },
  {
    id: 'banners',
    icon: 'banner',
    title: 'Banners & Displays',
    shortDesc: 'Make an impact at any event',
    fullDesc: 'We design and produce high-quality vinyl banners and display systems for trade shows, events, and promotions. From design to finished product — all in-house for better quality control.',
    image: '/images/work-banner.jpg',
    features: [
      'Vinyl banners (all sizes)',
      'Retractable banner stands',
      'Pop-up displays',
      'Step & repeat backdrops',
      'Feather & teardrop flags',
      'Trade show packages'
    ],
    priceRange: 'From $75',
    turnaround: '3-5 days'
  },
  {
    id: 'stickers',
    icon: 'sticker',
    title: 'Custom Stickers & Labels',
    shortDesc: 'Branding that sticks',
    fullDesc: 'Custom die-cut stickers, product labels, and decals — designed and manufactured by us. Perfect for packaging, promotions, and products. Waterproof and durable options available.',
    image: '/images/work-stickers.jpg',
    features: [
      'Die-cut stickers',
      'Product labels',
      'Clear stickers',
      'Holographic options',
      'Waterproof vinyl',
      'Sheet labels'
    ],
    priceRange: 'From $50',
    turnaround: '3-5 days'
  },
  {
    id: 'events',
    icon: 'wedding',
    title: 'Event Signage',
    shortDesc: 'Make your event memorable',
    fullDesc: 'Beautiful custom event signage — from design to finished piece. Welcome signs, seating charts, menus, and decorative pieces for weddings, corporate events, and celebrations.',
    image: '/images/work-wedding.jpg',
    features: [
      'Welcome signs',
      'Seating charts',
      'Menu boards',
      'Directional signs',
      'Photo backdrops',
      'Table numbers'
    ],
    priceRange: 'From $85',
    turnaround: '5-10 days'
  },
  {
    id: 'print',
    icon: 'print',
    title: 'Print Design',
    shortDesc: 'Professional marketing materials',
    fullDesc: 'Complete print design AND production services. We design and manufacture business cards, flyers, brochures, and marketing materials — quality controlled from start to finish.',
    image: '/images/work-menu.jpg',
    features: [
      'Business cards',
      'Flyers & brochures',
      'Posters',
      'Menus',
      'Presentation folders',
      'Direct mail pieces'
    ],
    priceRange: 'From $100',
    turnaround: '3-5 days'
  },
  {
    id: 'branding',
    icon: 'brand',
    title: 'Brand Identity',
    shortDesc: 'Cohesive brand design',
    fullDesc: 'Logo design and complete brand identity packages. Plus, we can produce all your branded materials — from business cards to signage — maintaining consistent quality across everything.', 
    image: '/images/work-branding.jpg',
    features: [
      'Logo design',
      'Color palette',
      'Typography system',
      'Brand guidelines',
      'Business stationery',
      'Social media assets'
    ],
    priceRange: 'From $500',
    turnaround: '1-2 weeks'
  }
];

const processSteps = [
  {
    number: '01',
    title: 'Consultation',
    description: 'We discuss your project, goals, and vision. Share inspiration, requirements, and any specific needs.'
  },
  {
    number: '02',
    title: 'Design',
    description: 'Our team creates initial concepts based on your brief. We focus on both aesthetics and functionality.'
  },
  {
    number: '03',
    title: 'Revision',
    description: 'Review the designs and provide feedback. We include unlimited revisions to get it perfect.'
  },
  {
    number: '04',
    title: 'Delivery',
    description: 'Receive print-ready files or finished physical products, depending on your project needs.'
  }
];
---

<Layout 
  title="Services"
  description="Explore our range of design services: custom signage, banners, stickers, event signage, print design, and brand identity packages."
>
  <Navigation />
  
  <main class="pt-24">
    <!-- Header -->
    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-6 text-center">
        <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">What We Offer</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 mb-4">
          Our Services
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          From concept to completion, we offer comprehensive design services for all your signage and print needs.
        </p>
      </div>
    </section>

    <!-- Services List -->
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="space-y-16">
          {services.map((service, index) => (
            <div id={service.id} class={`grid lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
              <!-- Content -->
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center">
                    {service.icon === 'signage' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                      </svg>
                    )}
                    {service.icon === 'banner' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    )}
                    {service.icon === 'sticker' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                      </svg>
                    )}
                    {service.icon === 'wedding' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                      </svg>
                    )}
                    {service.icon === 'print' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                      </svg>
                    )}
                    {service.icon === 'brand' && (
                      <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                      </svg>
                    )}
                  </div>
                  <span class="text-sm text-orange-500 font-semibold uppercase tracking-wider">{service.priceRange}</span>
                </div>
                <h2 class="text-3xl font-bold text-gray-900 mb-4">{service.title}</h2>
                <p class="text-gray-600 text-lg mb-6">{service.fullDesc}</p>
                
                <ul class="space-y-3 mb-8">
                  {service.features.map(feature => (
                    <li class="flex items-center gap-3">
                      <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span class="text-gray-700">{feature}</span>
                    </li>
                  ))}
                </ul>
                
                <div class="flex flex-wrap gap-4">
                  <a href="./contact.html" class="btn btn-primary">
                    Get a Quote
                  </a>
                  <span class="flex items-center text-gray-500 text-sm">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {service.turnaround} turnaround
                  </span>
                </div>
              </div>
              
              <!-- Image -->
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <div class="aspect-[4/3] rounded-2xl overflow-hidden">
                  <img 
                    src={service.image} 
                    alt={service.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="section bg-gray-900 text-white">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-orange-400 font-semibold text-sm uppercase tracking-wider">How It Works</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-2">
            Our Design Process
          </h2>
          <p class="text-gray-400 mt-4">
            Simple, transparent, and collaborative from start to finish.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {processSteps.map(step => (
            <div class="text-center">
              <div class="text-5xl font-bold text-orange-500 mb-4">{step.number}</div>
              <h3 class="text-xl font-bold mb-3">{step.title}</h3>
              <p class="text-gray-400">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="section bg-gray-50">
      <div class="container mx-auto px-6 max-w-3xl">
        <div class="text-center mb-12">
          <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">FAQ</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2">
            Common Questions
          </h2>
        </div>
        
        <div class="space-y-4">
          <div class="bg-white rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-2">Do you handle production or just design?</h3>
            <p class="text-gray-600">We offer both! We can deliver print-ready files for you to produce locally, or we can handle the entire production and ship finished products to you.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-2">What file formats will I receive?</h3>
            <p class="text-gray-600">You'll receive high-resolution PDFs, AI/EPS vector files, and PNGs with transparent backgrounds—everything you need for print and digital use.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-2">How many revisions are included?</h3>
            <p class="text-gray-600">All projects include unlimited revisions. We work until you're completely satisfied with the design.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6">
            <h3 class="font-semibold text-gray-900 mb-2">Do you offer rush orders?</h3>
            <p class="text-gray-600">Yes! Rush service is available for most projects. Contact us with your deadline and we'll let you know what we can do.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section bg-orange-500">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to Get Started?
        </h2>
        <p class="text-white/90 text-lg mb-8 max-w-2xl mx-auto">
          Contact us today for a free consultation and quote on your project.
        </p>
        <a href="./contact.html" class="btn bg-white text-orange-500 hover:bg-gray-100 text-lg px-8">
          Request a Quote
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
