---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const categories = ['All', 'Signage', 'Banners', 'Stickers', 'Events', 'Branding', 'Print'];

const portfolioItems = [
  {
    title: 'Modern Acrylic Store Sign',
    category: 'Signage',
    description: 'Backlit acrylic signage for retail boutique',
    client: 'Luxe Fashion Store',
    image: '/images/work-signage.jpg'
  },
  {
    title: 'Wedding Welcome Mirror',
    category: 'Events',
    description: 'Custom calligraphy on round mirror',
    client: 'Sarah & David Wedding',
    image: '/images/work-wedding.jpg'
  },
  {
    title: 'Trade Show Booth Display',
    category: 'Banners',
    description: '10x10 ft retractable banner system',
    client: 'TechStartup Inc.',
    image: '/images/work-banner.jpg'
  },
  {
    title: 'Product Label Set',
    category: 'Stickers',
    description: 'Waterproof labels for skincare line',
    client: 'Glow Beauty Co.',
    image: '/images/work-stickers.jpg'
  },
  {
    title: 'PVC Office Directory',
    category: 'Signage',
    description: 'Modern directory for office building',
    client: 'Metro Business Center',
    image: '/images/work-pvc.jpg'
  },
  {
    title: 'Brand Identity Package',
    category: 'Branding',
    description: 'Complete logo and stationery design',
    client: 'Artisan Coffee Roasters',
    image: '/images/work-branding.jpg'
  },
  {
    title: 'Event Seating Chart',
    category: 'Events',
    description: 'Large format poster seating chart',
    client: 'Grand Hotel Wedding',
    image: '/images/work-seating.jpg'
  },
  {
    title: 'Menu Board Design',
    category: 'Print',
    description: 'Chalkboard-style menu for cafe',
    client: 'The Corner Cafe',
    image: '/images/work-menu.jpg'
  },
  {
    title: 'Car Decal Wrap',
    category: 'Stickers',
    description: 'Partial wrap for service vehicle',
    client: 'Quick Fix Plumbing',
    image: '/images/work-car-decal.jpg'
  }
];
---

<Layout 
  title="Portfolio"
  description="Browse our portfolio of custom signage, banners, stickers, and print design projects for businesses and events."
>
  <Navigation />
  
  <main class="pt-24">
    <!-- Header -->
    <section class="bg-gray-50 py-16">
      <div class="container mx-auto px-6 text-center">
        <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Our Work</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 mb-4">
          Featured Projects
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Explore our portfolio of custom designs for businesses, events, and personal projects.
        </p>
      </div>
    </section>

    <!-- Portfolio Grid -->
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <!-- Filter Buttons -->
        <div class="flex flex-wrap justify-center gap-3 mb-12">
          {categories.map(cat => (
            <button 
              class="filter-btn px-6 py-2 rounded-full border-2 border-gray-200 text-gray-600 font-medium hover:border-orange-500 hover:text-orange-500 transition-colors"
              data-category={cat.toLowerCase()}
            >
              {cat}
            </button>
          ))}
        </div>
        
        <!-- Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="portfolio-grid">
          {portfolioItems.map((item, index) => (
            <div class="portfolio-item group" data-category={item.category.toLowerCase()}>
              <div class="card overflow-hidden">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img 
                    src={item.image} 
                    alt={item.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
                    <div class="absolute bottom-0 left-0 right-0 p-6">
                      <p class="text-white/80 text-sm mb-2">{item.description}</p>
                      <span class="text-orange-400 font-medium text-sm">View Project →</span>
                    </div>
                  </div>
                </div>
                <div class="p-6">
                  <span class="text-orange-500 text-sm font-medium">{item.category}</span>
                  <h3 class="text-lg font-bold text-gray-900 mt-1">{item.title}</h3>
                  <p class="text-gray-500 text-sm mt-1">Client: {item.client}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section bg-gray-50">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          Have a Project in Mind?
        </h2>
        <p class="text-gray-600 mb-8 max-w-xl mx-auto">
          We'd love to hear about your project. Get in touch for a free consultation and quote.
        </p>
        <a href="/contact.html" class="btn btn-primary text-lg px-8">
          Start Your Project
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  // Simple filter functionality
  const filterBtns = document.querySelectorAll('.filter-btn');
  const portfolioItems = document.querySelectorAll('.portfolio-item');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      
      // Update active state
      filterBtns.forEach(b => {
        b.classList.remove('bg-orange-500', 'text-white', 'border-orange-500');
        b.classList.add('border-gray-200', 'text-gray-600');
      });
      btn.classList.remove('border-gray-200', 'text-gray-600');
      btn.classList.add('bg-orange-500', 'text-white', 'border-orange-500');
      
      // Filter items
      portfolioItems.forEach(item => {
        if (category === 'all' || item.dataset.category === category) {
          item.style.display = 'block';
          item.classList.add('animate-fade-in-up');
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
  
  // Set 'All' as active by default
  filterBtns[0].classList.remove('border-gray-200', 'text-gray-600');
  filterBtns[0].classList.add('bg-orange-500', 'text-white', 'border-orange-500');
</script>
