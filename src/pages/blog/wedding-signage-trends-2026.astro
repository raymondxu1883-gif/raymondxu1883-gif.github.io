---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Wedding Signage Trends 2026 | SignSmith Studio";
const pageDescription = "Discover the latest wedding signage trends for 2026. Beautiful welcome signs, seating charts, and creative ideas for your special day.";
---

<Layout 
  title={pageTitle}
  description={pageDescription}
>
  <!-- BlogPosting Structured Data -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "Wedding Signage Trends 2026",
      "description": "Discover the latest wedding signage trends for 2026. Beautiful welcome signs, seating charts, and creative ideas for your special day.",
      "author": {
        "@type": "Organization",
        "name": "SignSmith Studio",
        "url": "https://signsmithstudio.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "SignSmith Studio",
        "logo": {
          "@type": "ImageObject",
          "url": "https://signsmithstudio.com/favicon.svg"
        }
      },
      "datePublished": "2026-04-23",
      "dateModified": "2026-04-23",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://signsmithstudio.com/blog/wedding-signage-trends-2026"
      }
    }
  </script>
  <Navigation />
  
  <main class="pt-24">
    <article class="bg-gray-50 py-16">
      <div class="container mx-auto px-6 max-w-4xl text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Coming Soon</h1>
        <p class="text-gray-600 text-lg">
          We're preparing this guide to 2026 wedding signage trends. Stay tuned!
        </p>
        <a href="/blog.html" class="btn btn-primary mt-8 inline-block">
          Back to Blog
        </a>
      </div>
    </article>
  </main>
  
  <Footer />
</Layout>
