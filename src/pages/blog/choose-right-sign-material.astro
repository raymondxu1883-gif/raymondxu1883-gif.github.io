---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "How to Choose the Right Sign Material | SignSmith Studio";
const pageDescription = "Learn which signage material works best for your business: acrylic, metal, PVC, wood, and more. Make an informed decision for your signage investment.";
---

<Layout 
  title={pageTitle}
  description={pageDescription}
>
  <Navigation />
  
  <main class="pt-24">
    <article class="bg-gray-50 py-16">
      <div class="container mx-auto px-6 max-w-4xl text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Coming Soon</h1>
        <p class="text-gray-600 text-lg">
          We're working on this comprehensive guide to sign materials. Check back soon!
        </p>
        <a href="/blog.html" class="btn btn-primary mt-8 inline-block">
          Back to Blog
        </a>
      </div>
    </article>
  </main>
  
  <Footer />
</Layout>
