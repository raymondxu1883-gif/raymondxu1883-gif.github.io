---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "SignSmith Studio | Professional Signs for Small Businesses";
const pageDescription = "We help small shops, local businesses, and individuals get professional signs — easily, affordably, and with a personal touch. No design experience needed!";

const services = [
  {
    icon: 'signage',
    title: 'Custom Signage',
    description: 'Eye-catching signs for businesses, events, and retail spaces. Acrylic, PVC, metal, and more.',
    link: './services.html#signage'
  },
  {
    icon: 'banner',
    title: 'Banners & Displays',
    description: 'Vinyl banners, retractable stands, and trade show displays that make an impact.',
    link: './services.html#banners'
  },
  {
    icon: 'sticker',
    title: 'Custom Stickers',
    description: 'Die-cut stickers, labels, and decals for products, packaging, and promotions.',
    link: './services.html#stickers'
  },
  {
    icon: 'print',
    title: 'Print Design',
    description: 'Business cards, flyers, brochures, and marketing materials designed to impress.',
    link: './services.html#print'
  },
  {
    icon: 'wedding',
    title: 'Event Signage',
    description: 'Welcome signs, seating charts, and custom pieces for weddings and special events.',
    link: './services.html#events'
  },
  {
    icon: 'brand',
    title: 'Brand Identity',
    description: 'Logo design and cohesive branding packages to elevate your business image.',
    link: './services.html#branding'
  }
];

const featuredWorks = [
  {
    title: 'Modern Retail Signage',
    category: 'Signage',
    image: '/images/work-signage.jpg',
    alt: 'Modern acrylic signage for retail store'
  },
  {
    title: 'Wedding Welcome Sign',
    category: 'Events',
    image: '/images/work-wedding.jpg',
    alt: 'Elegant wedding welcome sign'
  },
  {
    title: 'Trade Show Display',
    category: 'Banners',
    image: '/images/work-banner.jpg',
    alt: 'Professional trade show banner display'
  },
  {
    title: 'Brand Identity Package',
    category: 'Branding',
    image: '/images/work-branding.jpg',
    alt: 'Complete brand identity design'
  }
];

const testimonials = [
  {
    quote: "The signage they designed for our store opening was absolutely stunning. Professional, timely, and exactly what we envisioned.",
    author: "Sarah Mitchell",
    role: "Store Owner, Brooklyn NY"
  },
  {
    quote: "Our wedding welcome sign was the talk of the reception. Beautiful craftsmanship and attention to detail.",
    author: "Emma & James",
    role: "Wedding Clients"
  },
  {
    quote: "Fast turnaround on our trade show banners. Quality exceeded expectations and helped us stand out at the event.",
    author: "Michael Chen",
    role: "Marketing Director"
  }
];
---

<Layout 
  title={pageTitle}
  description={pageDescription}
>
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="pt-32 pb-20 lg:pt-40 lg:pb-32 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-orange-500 font-semibold text-sm uppercase tracking-wider mb-4">We Make the Mark</p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
            Professional Signs for <span class="text-orange-500">Small Shops</span> & <span class="text-orange-500">Local Businesses</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-600 mb-4 max-w-2xl mx-auto">
            No design experience? No problem. We help small businesses get great signage — easily, affordably, and with a smile.
          </p>
          <p class="text-gray-500 text-base mb-8">
            ✨ From concept to finished product — we guide you every step of the way
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="./portfolio.html" class="btn btn-primary text-lg px-8">
              View Our Work
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="./contact.html" class="btn btn-outline text-lg px-8">
              Get a Free Quote
            </a>
          </div>
          
          <!-- Industry showcase -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <p class="text-sm text-gray-500 mb-6">Trusted by businesses across industries</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
              <!-- Fashion Retail -->
              <div class="relative group overflow-hidden rounded-xl aspect-[4/3]">
                <img 
                  src="/images/work-signage.jpg" 
                  alt="Fashion Retail Store Signage"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 to-transparent flex items-end">
                  <span class="text-white font-semibold text-sm p-3">Fashion Retail</span>
                </div>
              </div>
              <!-- Restaurants -->
              <div class="relative group overflow-hidden rounded-xl aspect-[4/3]">
                <img 
                  src="/images/work-menu.jpg" 
                  alt="Restaurant Menu Board"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 to-transparent flex items-end">
                  <span class="text-white font-semibold text-sm p-3">Restaurants</span>
                </div>
              </div>
              <!-- Events -->
              <div class="relative group overflow-hidden rounded-xl aspect-[4/3]">
                <img 
                  src="/images/work-wedding.jpg" 
                  alt="Wedding Event Signage"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 to-transparent flex items-end">
                  <span class="text-white font-semibold text-sm p-3">Events</span>
                </div>
              </div>
              <!-- Startups -->
              <div class="relative group overflow-hidden rounded-xl aspect-[4/3]">
                <img 
                  src="/images/work-branding.jpg" 
                  alt="Startup Brand Identity"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 to-transparent flex items-end">
                  <span class="text-white font-semibold text-sm p-3">Startups</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">What We Do</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">
            Design Services Tailored to Your Needs
          </h2>
          <p class="text-gray-600">
            From concept to finished product, we handle every step of your design project with precision and creativity.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map(service => (
            <a href={service.link} class="card p-8 group hover:border-orange-500 border-2 border-transparent transition-all">
              <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-500 transition-colors">
                {service.icon === 'signage' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                  </svg>
                )}
                {service.icon === 'banner' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                )}
                {service.icon === 'sticker' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                  </svg>
                )}
                {service.icon === 'print' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                  </svg>
                )}
                {service.icon === 'wedding' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                  </svg>
                )}
                {service.icon === 'brand' && (
                  <svg class="w-7 h-7 text-orange-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">{service.title}</h3>
              <p class="text-gray-600 mb-4">{service.description}</p>
              <span class="text-orange-500 font-medium inline-flex items-center group-hover:translate-x-2 transition-transform">
                Learn More
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Work Section -->
    <section class="section bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12">
          <div class="max-w-xl">
            <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Portfolio</span>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2">
              Featured Projects
            </h2>
            <p class="text-gray-600 mt-4">
              A selection of our recent work across signage, events, and branding.
            </p>
          </div>
          <a href="./portfolio.html" class="btn btn-outline mt-6 md:mt-0">
            View All Work
          </a>
        </div>
        
        <div class="portfolio-grid">
          {featuredWorks.map(work => (
            <div class="card group cursor-pointer overflow-hidden">
              <div class="relative overflow-hidden aspect-[4/3]">
                <img 
                  src={work.image} 
                  alt={work.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="absolute bottom-4 left-4 right-4">
                    <span class="text-white/90 text-sm font-medium">{work.category}</span>
                    <h3 class="text-white font-bold text-lg">{work.title}</h3>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="section bg-white">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Why Choose Us</span>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6">
              Years of Experience, Endless Creativity
            </h2>
            <p class="text-gray-600 mb-6">
              With a background in international trade and graphic design, we understand both the creative and business sides of your project. We deliver designs that not only look great but also achieve your goals.
            </p>
            
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Fast Turnaround</h3>
                  <p class="text-gray-600 text-sm">Most projects completed within 3-5 business days.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Unlimited Revisions</h3>
                  <p class="text-gray-600 text-sm">We work until you're 100% satisfied with the design.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Print-Ready Files</h3>
                  <p class="text-gray-600 text-sm">Professional files optimized for any printing method.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Design + Production</h3>
                  <p class="text-gray-600 text-sm">We design AND manufacture. Direct factory partnerships mean better prices & quality control.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="relative">
            <div class="aspect-square rounded-2xl bg-gradient-to-br from-orange-100 to-gray-200 flex items-center justify-center">
              <div class="text-center p-8">
                <div class="text-5xl font-bold text-orange-500 mb-2">500+</div>
                <div class="text-gray-600">Projects Completed</div>
              </div>
            </div>
            <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-6">
              <div class="flex items-center gap-4">
                <div class="flex -space-x-2">
                  <div class="w-10 h-10 rounded-full bg-orange-200"></div>
                  <div class="w-10 h-10 rounded-full bg-orange-300"></div>
                  <div class="w-10 h-10 rounded-full bg-orange-400"></div>
                </div>
                <div>
                  <div class="font-semibold text-gray-900">98% Satisfaction</div>
                  <div class="text-sm text-gray-500">From happy clients</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section bg-gray-900 text-white">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-orange-400 font-semibold text-sm uppercase tracking-wider">Testimonials</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-2">
            What Our Clients Say
          </h2>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {testimonials.map(t => (
            <div class="bg-gray-800 rounded-2xl p-8">
              <svg class="w-10 h-10 text-orange-500 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
              <p class="text-gray-300 mb-6">{t.quote}</p>
              <div>
                <div class="font-semibold">{t.author}</div>
                <div class="text-gray-400 text-sm">{t.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section bg-orange-500">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Ready to Start Your Project?
        </h2>
        <p class="text-white/90 text-lg mb-8 max-w-2xl mx-auto">
          Get a free quote within 24 hours. No commitment required.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="./contact.html" class="btn bg-white text-orange-500 hover:bg-gray-100 text-lg px-8">
            Get a Free Quote
          </a>
          <a href="./portfolio.html" class="btn border-2 border-white text-white hover:bg-white hover:text-orange-500 text-lg px-8">
            Browse Portfolio
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
